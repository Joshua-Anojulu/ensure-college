# Anthropic API key for server-side essay advice.
# Copy this file to .env and paste your real key there. .env is gitignored.
ANTHROPIC_API_KEY=

# AI-backed help (essay/program advice, resume auto-fill) is OFF by default.
# Leave unset/false to run with zero AI API cost. Set true only when
# ANTHROPIC_API_KEY is configured. ANTHROPIC_API_KEY is optional while off.
# AI_FEATURES_ENABLED=false

# Secret used to sign login session cookies.
# Use any long random string locally. In production, set a strong unique value
# in the host's environment (Render can generate one for you).
SESSION_SECRET=

# Database connection. Leave unset to use a local SQLite file (scholarships4u.db).
# In production set this to a Postgres URL, for example the one Render provides.
# DATABASE_URL=

# Set to true in production (HTTPS) so session cookies are sent only over HTTPS.
# Leave unset or false for local HTTP development.
# SESSION_COOKIE_SECURE=

# Transactional email for password reset. Create a Resend API key and verify
# the sender domain before filling these in. PUBLIC_APP_URL must be the public
# HTTPS URL users should return to after clicking a reset link.
# RESEND_API_KEY=
# EMAIL_FROM="EnsureCollege <no-reply@mail.ensurecollege.com>"
# PUBLIC_APP_URL=https://ensurecollege.com

# Google OAuth sign-in. Create a Web application OAuth client in Google Cloud.
# Authorized redirect URIs:
# - https://ensurecollege.com/auth/google/callback
# - http://localhost:8099/auth/google/callback
# Never commit real secrets.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# --- Serverless (Vercel) hosting only ---
# Postgres: use a Neon POOLED connection string (has -pooler in the host).
# DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.neon.tech/db?sslmode=require
# Distributed rate limiting (required on serverless; in-memory won't work):
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Run Alembic in the Vercel build step instead of on cold start:
# RUN_MIGRATIONS_ON_STARTUP=false
